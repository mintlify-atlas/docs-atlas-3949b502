{
  "projectType": "saas",
  "projectName": "Manitern Pro",
  "projectDescription": "A Laravel-based internship management platform for tracking trainees, stages, absences, attestations, and institutional relationships.",
  "theme": "almond",
  "primaryColor": "#040404",
  "lightColor": "#ef370f",
  "darkColor": "#f79d72",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "getting-started/installation", "getting-started/configuration"]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/dashboard",
              "features/stagiaires",
              "features/stages",
              "features/absences",
              "features/attestations"
            ]
          },
          {
